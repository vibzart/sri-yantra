{
  "name": "@vibzart/sri-yantra",
  "version": "0.3.1",
  "description": "Mathematically precise Sri Yantra generator — SVG, Canvas, Three.js, React. Shastra-validated sacred geometry with zero-dep core.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./svg": {
      "types": "./dist/svg/index.d.ts",
      "import": "./dist/svg/index.js",
      "default": "./dist/svg/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js",
      "default": "./dist/canvas/index.js"
    },
    "./three": {
      "types": "./dist/three/index.d.ts",
      "import": "./dist/three/index.js",
      "default": "./dist/three/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    }
  },
  "bin": {
    "sri-yantra": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "node dist/cli.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run lint && npm run test"
  },
  "keywords": [
    "sri-yantra",
    "sacred-geometry",
    "svg",
    "canvas",
    "threejs",
    "react",
    "webgl",
    "3d",
    "yantra",
    "sanskrit",
    "vedic",
    "mandala",
    "hindu",
    "shakti",
    "shiva",
    "faithtech",
    "animation"
  ],
  "author": "Vibz.Art Studio <hello@vibz.art>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vibzart/sri-yantra"
  },
  "homepage": "https://vibz.art/tools/sri-yantra",
  "peerDependencies": {
    "@react-three/drei": ">=9.0.0 || >=10.0.0",
    "@react-three/fiber": ">=9.0.0",
    "react": ">=18.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "@react-three/drei": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.0",
    "@types/sharp": "^0.32.0",
    "@types/three": "^0.170.0",
    "react": "^19.0.0",
    "sharp": "^0.34.5",
    "three": "^0.170.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@vibzart/sri-yantra": "^0.2.1"
  }
}
